# Supabase Cloud Storage (For storing original/enrolled voice WAV files)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET_NAME="audiobooks"

# RunPod Serverless Configurations (For offloading voice cloning to GPU)
# Optional: if left blank, voice cloning will attempt to execute on your local machine (requires local GPU/PyTorch).
RUNPOD_ENDPOINT_ID="your-runpod-endpoint-id"
RUNPOD_API_KEY="your-runpod-api-key"
