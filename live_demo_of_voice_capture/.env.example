# Copy this file to .env and adjust as needed.
# Read automatically by `docker compose` (via run.sh or `docker compose up`) when present in this
# folder; for a manual (non-Docker) run, `export` these instead or use `python-dotenv` yourself.

# ── Module 2 auto-chaining ──────────────────────────────────────────────────
# Auto-start voice cloning right after a passing Module 1 capture. Set to 0/false/no to disable
# (Module 2 can still be run manually from /module2 or `python -m module2.run`).
MODULE2_AUTOCLONE=1

# Which registered cloning model (module2/registry.py) to use for the auto-chained run.
MODULE2_DEFAULT_MODEL=voxcpm

# ── CORS (frontend integration) ─────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API from the browser. "*" (default) allows
# any origin — fine for local dev, but set this to your actual frontend origin(s) in production,
# e.g.: CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=*

# ── Legacy server-side recorder (CaptureSession) ────────────────────────────
# Only used by the old server-side mic recorder (session.py), not the browser capture path the
# web app uses today. Safe to leave unset.
# AUDIO_DEVICE=
# AUDIO_SR=44100
